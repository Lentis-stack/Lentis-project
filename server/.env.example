# Copy to .env and adjust.

PORT=3001

# Used to generate URLs returned to the frontend.
# If deploying to a server, set to your domain.
PUBLIC_URL=http://localhost:3001

# Local disk folder to store uploads
STORAGE_ROOT=./uploads

# Hard upload size limit per file (MB)
MAX_FILE_SIZE=60MB

# Soft per-event caps enforced on in-memory index
MAX_IMAGES_PER_EVENT=3000
MAX_VIDEOS_PER_EVENT=500

